# ---------------------------------------------------------------------------
# Emarath Frontend — environment template
# All browser-exposed variables MUST be prefixed with NEXT_PUBLIC_.
# These are inlined at BUILD time, so set them per environment when building
# / deploying (e.g. per Vercel environment). No secrets belong here.
# ---------------------------------------------------------------------------

# Public application name.
NEXT_PUBLIC_APP_NAME=Emarath

# Logical application environment: development | staging | production
# NOTE: This is separate from Node's NODE_ENV (which only supports
# development/production/test). Use this variable to distinguish staging
# from production, set per deployment.
NEXT_PUBLIC_APP_ENV=development

# Base URL of the Emarath backend API (includes the /api prefix).
# Local default points at the backend running on port 5000.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
