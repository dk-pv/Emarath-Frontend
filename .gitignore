# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit real secrets or *.local overrides)
.env*
# ...but do track non-secret templates and public dev defaults:
!.env.example
!.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
